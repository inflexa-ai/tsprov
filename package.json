{
  "name": "tsprov",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "bun run --cwd packages/tsprov bootstrap",
    "test": "bun run --cwd packages/tsprov test",
    "build": "bun run --cwd packages/tsprov build",
    "smoke": "bun run --cwd packages/tsprov smoke",
    "eval": "TSPROV_EVAL_FULL=1 bun test packages/evals packages/tsprov-render"
  }
}
