{
  "name": "@inflexa-ai/tsprov-render-interactive",
  "version": "0.1.0",
  "description": "Interactive HTML renderer for tsprov provenance documents — renderInteractiveHtml(doc) emits ONE self-contained, animated, explorable HTML file (inline CSS/JS, the dagre-positioned scene baked in as JSON) that opens from file:// with nothing installed. Pan/zoom, progressive disclosure, an attribute panel, and search over the W3C PROV visual language.",
  "keywords": [
    "prov",
    "provenance",
    "w3c",
    "prov-dm",
    "visualization",
    "render",
    "interactive",
    "html"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inflexa-ai/tsprov.git",
    "directory": "packages/tsprov-render-interactive"
  },
  "homepage": "https://github.com/inflexa-ai/tsprov/tree/main/packages/tsprov-render-interactive#readme",
  "bugs": {
    "url": "https://github.com/inflexa-ai/tsprov/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "NOTICE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun run build:esm && bun run build:cjs",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "gen": "bun scripts/generate-template.mjs",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@inflexa-ai/tsprov-render-core": "^0.1.0",
    "@inflexa-ai/tsprov-render-svg": "^0.1.0"
  },
  "peerDependencies": {
    "@inflexa-ai/tsprov": ">=0.5.1 <2"
  },
  "devDependencies": {
    "@inflexa-ai/tsprov": "workspace:*",
    "@inflexa-ai/tsprov-render-core": "workspace:*",
    "@inflexa-ai/tsprov-render-svg": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^7"
  }
}
