digraph G {
rankdir=BT;
charset="utf-8";
n1 [label="ex:ag1", URL="http://example.org/ag1", shape=house, style=filled, fillcolor="#FED37F"];
n2 [label="ex:ag2", URL="http://example.org/ag2", shape=house, style=filled, fillcolor="#FED37F"];
